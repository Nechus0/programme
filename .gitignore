# OS / editor junk
.DS_Store
**/.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/settings.local.json

# Local env / secrets (never commit)
.env
.env.*

# Source material / large binaries (kept in the workspace, not the deploy repo)
*.pdf
# Ausnahme: ausgelieferte Aufklärungs-/Formular-PDFs (werden von der App verlinkt)
!assets/docs/
!assets/docs/*.pdf

# Python dev artefacts
__pycache__/
*.pyc
venv/

# Node dev artefacts (Test-Tools wie jsdom; nie deployen)
node_modules/
package-lock.json

# FUSE mount artefacts / bridge locks (never deploy)
.fuse_hidden*
_git_locks_to_delete/
